y/__/c10420p1116988902/i5521325516.jpg?pictureSize=W320\",\"small\":\"https://cdn.wallapop.com/images/10420/ih/0y/__/c10420p1116988902/i5521325516.jpg?pictureSize=W320\",\"large\":\"https://cdn.wallapop.com/images/10420/ih/0y/__/c10420p1116988902/i5521325516.jpg?pictureSize=W800\",\"medium\":\"https://cdn.wallapop.com/images/10420/ih/0y/__/c10420p1116988902/i5521325516.jpg?pictureSize=W640\",\"xlarge\":\"https://cdn.wallapop.com/images/10420/ih/0y/__/c10420p1116988902/i5521325516.jpg?pictureSize=W800\",\"original_width\":0,\"original_height\":0},{\"original\":\"https://cdn.wallapop.com/images/10420/ih/0y/__/c10420p1116988902/i5521325451.jpg?pictureSize=W800\",\"xsmall\":\"https://cdn.wallapop.com/images/10420/ih/0y/__/c10420p1116988902/i5521325451.jpg?pictureSize=W320\",\"small\":\"https://cdn.wallapop.com/images/10420/ih/0y/__/c10420p1116988902/i5521325451.jpg?pictureSize=W320\",\"large\":\"https://cdn.wallapop.com/images/10420/ih/0y/__/c10420p1116988902/i5521325451.jpg?pictureSize=W800\",\"medium\":\"https://cdn.wallapop.com/images/10420/ih/0y/__/c10420p1116988902/i5521325451.jpg?pictureSize=W640\",\"xlarge\":\"https://cdn.wallapop.com/images/10420/ih/0y/__/c10420p1116988902/i5521325451.jpg?pictureSize=W800\",\"original_width\":0,\"original_height\":0},{\"original\":\"https://cdn.wallapop.com/images/10420/ih/0y/__/c10420p1116988902/i5521325490.jpg?pictureSize=W800\",\"xsmall\":\"https://cdn.wallapop.com/images/10420/ih/0y/__/c10420p1116988902/i5521325490.jpg?pictureSize=W320\",\"small\":\"https://cdn.wallapop.com/images/10420/ih/0y/__/c10420p1116988902/i5521325490.jpg?pictureSize=W320\",\"large\":\"https://cdn.wallapop.com/images/10420/ih/0y/__/c10420p1116988902/i5521325490.jpg?pictureSize=W800\",\"medium\":\"https://cdn.wallapop.com/images/10420/ih/0y/__/c10420p1116988902/i5521325490.jpg?pictureSize=W640\",\"xlarge\":\"https://cdn.wallapop.com/images/10420/ih/0y/__/c10420p1116988902/i5521325490.jpg?pictureSize=W800\",\"original_width\":0,\"original_height\":0}],\"user\":{\"id\":\"wzynre0qvpj5\",\"micro_name\":\"\",\"image\":{\"original\":\"\",\"xsmall\":\"\",\"small\":\"\",\"large\":\"\",\"medium\":\"\",\"xlarge\":\"\",\"original_width\":0,\"original_height\":0},\"online\":false,\"kind\":\"normal\"},\"flags\":{\"pending\":false,\"sold\":false,\"reserved\":false,\"banned\":false,\"expired\":false,\"onhold\":false},\"visibility_flags\":{\"bumped\":false,\"highlighted\":false,\"urgent\":false,\"country_bumped\":false,\"boosted\":false},\"price\":49999.0,\"currency\":\"EUR\",\"web_slug\":\"porsche-911-carrera-s-1116988902\",\"category_id\":100,\"location\":{\"postal_code\":\"28700\",\"city\":\"San Sebastián de Los Reyes\",\"country_code\":\"ES\"},\"shipping\":{\"item_is_shippable\":false,\"user_allows_shipping\":false,\"cost_configuration_id\":null},\"supports_shipping\":false,\"brand\":\"Porsche\",\"model\":\"911\",\"year\":2005,\"version\":\"997 Carrera S Cabrio 3.8 355 2p Tip\",\"km\":96000,\"engine\":\"Gasolina\",\"gearbox\":\"automatic\",\"horsepower\":355.0,\"favorited\":false,\"creation_date\":\"2025-03-29T12:53:15.638+00:00\",\"modification_date\":\"2025-04-03T08:54:47.069+00:00\",\"is_top_profile\":false}},{\"id\":\"pj9m1kxqnm6e\",\"type\":\"cars_search_cars\",\"content\":{\"id\":\"pj9m1kxqnm6e\",\"title\":\"POrsche 911 (997) MKI MY08\",\"storytelling\":\"Nacional, matriculado por primera vez en noviembre de 2007, modelo 2008, último de comercialización del 997 mki, con IMS “reforzado”. Interior marrón en estado como nuevo. Y con una buena lista de equipamiento opcional, en que destacan los faros de xenón o el asistente de aparcamiento, cronómetro central y volante en cuero.\\n\\nPerfecta trazabilidad tanto en cuanto a libro de mantenimiento como base de datos de taller e historial de ITVs. Usado de manera continuada, sin observación de parones en su historial, con seguimiento constante de mantenimientos a intervalos regulares. El siguiente mantenimiento le toca ahora y será realizado en TAREDBLAU previamente a la entrega del vehículo.\\n\\nSe le ha realizado prueba de compresión y bore scoring y ha dado un resultado óptimo, algo fundamental en este modelo. Sin duda, es una unidad en un estado como hay pocas\\n\\nOPCIONES DE FÁBRICA\\nC27 – unidad fabricada para España\\nXRP – espaciadores de 5mm en todas las llantas\\n025 – cronómetro con esfera en negro\\n249 – tiptronic\\n267 – retrovisores con regulación automática\\n288 – lavafaros\\n425 – limpiaparabrisas trasero\\n432 – botones Tiptronic en el volante\\n435 – volante de cuero\\n482 – sensor de presión de neumáticos\\n567 – parabrisas superior tintado\\n601 – faros de xenon\\n610 – sistema de navegación\\n635 – asistente de aparcamiento\\n09971 – programa de equipamiento especial\\nSEGUIMIENTO DE KILOMETRAJE\\nHistórico de kilometraje plenamente coherente en informes de la DGT, libro de mantenimiento y base de datos Porsche.\\n\\nNoviembre de 2009: 14.114KM\\nNoviembre de 2011: 23.644KM\\nNoviembre de 2013: 36.829KM\\nNoviembre de 2015: 50.171 KM\\nNoviembre de 2017: 59.540 KM\\nFebrero de 2020: 75.566 KM\\nAgosto de 2022: 95.911 KM\\nEnero de 2024: 102.598 KM\\nFebrero de 2025: 104.702\\n\",\"distance\":18.0,\"images\":[{\"original\":\"https://cdn.wallapop.com/images/10420/if/yy/__/c10420p1115216813/i5503328909.jpg?pictureSize=W800\",\"xsmall\":\"https://cdn.wallapop.com/images/10420/if/yy/__/c10420p1115216813/i5503328909.jpg?pictureSize=W320\",\"small\":\"https://cdn.wallapop.com/images/10420/if/yy/__/c10420p1115216813/i5503328909.jpg?pictureSize=W320\",\"large\":\"https://cdn.wallapop.com/images/10420/if/yy/__/c10420p1115216813/i5503328909.jpg?pictureSize=W800\",\"medium\":\"https://cdn.wallapop.com/images/10420/if/yy/__/c10420p1115216813/i5503328909.jpg?pictureSize=W640\",\"xlarge\":\"https://cdn.wallapop.com/images/10420/if/yy/__/c10420p1115216813/i5503328909.jpg?pictureSize=W800\",\"original_width\":0,\"original_height\":0},{\"original\":\"https://cdn.wallapop.com/images/10420/if/yy/__/c10420p1115216813/i5503328931.jpg?pictureSize=W800\",\"xsmall\":\"https://cdn.wallapop.com/images/10420/if/yy/__/c10420p1115216813/i5503328931.jpg?pictureSize=W320\",\"small\":\"https://cdn.wallapop.com/images/10420/if/yy/__/c10420p1115216813/i5503328931.jpg?pictureSize=W320\",\"large\":\"https://cdn.wallapop.com/images/10420/if/yy/__/c10420p1115216813/i5503328931.jpg?pictureSize=W800\",\"medium\":\"https://cdn.wallapop.com/images/10420/if/yy/__/c10420p1115216813/i5503328931.jpg?pictureSize=W640\",\"xlarge\":\"https://cdn.wallapop.com/images/10420/if/yy/__/c10420p1115216813/i5503328931.jpg?pictureSize=W800\",\"original_width\":0,\"original_height\":0},{\"original\":\"https://cdn.wallapop.com/images/10420/if/yy/__/c10420p1115216813/i5503328961.jpg?pictureSize=W800\",\"xsmall\":\"https://cdn.wallapop.com/images/10420/if/yy/__/c10420p1115216813/i5503328961.jpg?pictureSize=W320\",\"small\":\"https://cdn.wallapop.com/images/10420/if/yy/__/c10420p1115216813/i5503328961.jpg?pictureSize=W320\",\"large\":\"https://cdn.wallapop.com/images/10420/if/yy/__/c10420p1115216813/i5503328961.jpg?pictureSize=W800\",\"medium\":\"https://cdn.wallapop.com/images/10420/if/yy/__/c10420p1115216813/i5503328961.jpg?pictureSize=W640\",\"xlarge\":\"https://cdn.wallapop.com/images/10420/if/yy/__/c10420p1115216813/i5503328961.jpg?pictureSize=W800\",\"original_width\":0,\"original_height\":0},{\"original\":\"https://cdn.wallapop.com/images/10420/if/yy/__/c10420p1115216813/i5503329070.jpg?pictureSize=W800\",\"xsmall\":\"https://cdn.wallapop.com/images/10420/if/yy/__/c10420p1115216813/i5503329070.jpg?pictureSize=W320\",\"small\":\"https://cdn.wallapop.com/images/10420/if/yy/__/c10420p1115216813/i5503329070.jpg?pictureSize=W320\",\"large\":\"https://cdn.wallapop.com/images/10420/if/yy/__/c10420p1115216813/i5503329070.jpg?pictureSize=W800\",\"medium\":\"https://cdn.wallapop.com/images/10420/if/yy/__/c10420p1115216813/i5503329070.jpg?pictureSize=W640\",\"xlarge\":\"https://cdn.wallapop.com/images/10420/if/yy/__/c10420p1115216813/i5503